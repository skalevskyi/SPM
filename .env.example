# Public site URL (metadata, sitemap, emails, canonical). Defaults to https://www.spmads.fr if unset.
# NEXT_PUBLIC_SITE_URL=

# Resend — required for POST /api/lead (set in Vercel for production)
RESEND_API_KEY=

# Inbox that receives lead notifications — required in production (no placeholder fallback in code)
LEAD_TO_EMAIL=

# Sender shown by Resend. Optional for local/tests (defaults to Resend onboarding address).
# Production: set to an address on a domain verified in Resend.
# RESEND_FROM_EMAIL=

# Lead API rate limit (in-memory per serverless instance). Defaults: 12 requests / 15 minutes per IP.
# LEAD_RATE_LIMIT_MAX=12
# LEAD_RATE_LIMIT_WINDOW_MS=900000

# Lead backup persistence (Upstash Redis REST — required in production for durable recovery if email fails).
# Create a Redis database at https://upstash.com and paste REST URL + token.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Optional Redis list key (default: spm:leads:backup)
# LEAD_BACKUP_LIST_KEY=

# Local/dev ONLY: skip backup (no durable copy). Do not enable in production.
# LEAD_BACKUP_SKIP=false
